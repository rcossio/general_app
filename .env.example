# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql://user:password@localhost:5432/appdb
# Used by Vitest integration tests — separate DB to avoid clobbering prod data
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/appdb_test

# ============================================================
# Auth (JWT)
# ============================================================
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com

# ============================================================
# Seed credentials (only used during: npx prisma db seed)
# ============================================================
ADMIN_EMAIL=
ADMIN_PASSWORD=

# ============================================================
# Google OAuth
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: https://yourdomain.com/api/auth/google/callback
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# Email (Resend — transactional email for password resets, etc.)
# Sign up at resend.com, verify your domain, get API key
# Free tier: 100 emails/day
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================================
# Cloudflare R2 (object storage for user-uploaded files)
# Never serve uploads from the VPS — only store R2 URLs in DB
# Free tier: 10GB storage, no egress fees
# ============================================================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL of your R2 bucket (set up a custom domain or use the R2.dev subdomain)
NEXT_PUBLIC_R2_PUBLIC_URL=

# ============================================================
# Map tiles (MapTiler — optional)
# Sign up at cloud.maptiler.com → API keys. Lock the key to your domains
# (allowed origins) in the dashboard since it ships to the browser.
# Leave NEXT_PUBLIC_MAP_PROVIDER=osm to use free OpenStreetMap tiles;
# set it to "maptiler" to activate MapTiler. If maptiler is selected but the
# key is missing, the app falls back to OSM automatically.
# (NEXT_PUBLIC_* vars are inlined at build time — rebuild after changing.)
# ============================================================
NEXT_PUBLIC_MAP_PROVIDER=osm
NEXT_PUBLIC_MAPTILER_KEY=
NEXT_PUBLIC_MAPTILER_STYLE=streets-v4

# ============================================================
# Analytics (optional — loaded only AFTER cookie consent)
# Tool-agnostic. Example values shown are for a self-hosted Umami instance.
# Leave blank to ship the consent banner without any analytics yet.
# ============================================================
NEXT_PUBLIC_ANALYTICS_SRC=
NEXT_PUBLIC_ANALYTICS_WEBSITE_ID=
