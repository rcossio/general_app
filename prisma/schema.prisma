// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// SECTION: Core (auth, users, RBAC)
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  userRoles       UserRole[]
  refreshTokens   RefreshToken[]
  workoutRoutines WorkoutRoutine[]
  trackerEntries  TrackerEntry[]
  gameSessions    GameSession[]

  @@map("users")
}

model Role {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id       String @id @default(cuid())
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  userId String @map("user_id")
  roleId String @map("role_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================================
// SECTION: Workout Module
// ============================================================

model WorkoutRoutine {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  name        String
  description String?
  isPublic    Boolean  @default(false) @map("is_public")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  days WorkoutDay[]

  @@index([userId])
  @@index([isPublic, createdAt])
  @@map("workout_routines")
}

model WorkoutDay {
  id        String @id @default(cuid())
  routineId String @map("routine_id")
  dayOfWeek Int    @map("day_of_week")
  name      String

  routine   WorkoutRoutine    @relation(fields: [routineId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]

  @@index([routineId])
  @@map("workout_days")
}

model WorkoutExercise {
  id              String  @id @default(cuid())
  dayId           String  @map("day_id")
  name            String
  sets            Int?
  reps            Int?
  durationSeconds Int?    @map("duration_seconds")
  restSeconds     Int?    @map("rest_seconds")
  notes           String?
  order           Int

  day WorkoutDay @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
  @@map("workout_exercises")
}

// ============================================================
// SECTION: Adventure Module
// ============================================================

model Game {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       Json
  description String?
  chapter     Int      @default(1)
  nextGameId  String?  @unique @map("next_game_id")
  isActive    Boolean  @default(false) @map("is_active")
  // Array of { id, flag, name: {en,it,es}, imageUrl? }
  items       Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  locations GameLocation[]
  sessions  GameSession[]

  @@map("games")
}

model GameLocation {
  id          String @id @default(cuid())
  gameId      String @map("game_id")
  externalId  String @map("external_id")
  name        Json
  lat         Float
  lng         Float
  radiusM     Int    @default(35) @map("radius_m")
  // null | "flag_string" | { and: Condition[] } | { or: Condition[] }
  visibleWhen Json?  @map("visible_when")
  // Array of { when: Condition | null, content: { en, it, es }, completesChapter?: true }
  values      Json
  // "location" (default) | "event" — events auto-fire on radius entry, no sheet
  type        String  @default("location")
  imageUrl    String? @map("image_url")
  // Array of { flag: string }
  grants      Json
  // Array of { flag: string } — flags removed from session on visit
  revokes     Json   @default("[]")
  order           Int     @default(0)
  // True on the one location where the player should start (used by fake GPS to teleport)
  initialLocation Boolean @default(false) @map("initial_location")

  game   Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  visits LocationVisit[]

  @@unique([gameId, externalId])
  @@index([gameId])
  @@map("game_locations")
}

model GameSession {
  id          String    @id @default(cuid())
  gameId      String    @map("game_id")
  userId      String    @map("user_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  game   Game            @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  flags  SessionFlag[]
  visits LocationVisit[]

  @@unique([gameId, userId])
  @@index([userId])
  @@map("game_sessions")
}

model SessionFlag {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  flag      String
  setAt     DateTime    @default(now()) @map("set_at")

  session GameSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, flag])
  @@index([sessionId])
  @@map("session_flags")
}

model LocationVisit {
  id         String   @id @default(cuid())
  sessionId  String   @map("session_id")
  locationId String   @map("location_id")
  status     String   @default("open")
  visitedAt  DateTime @default(now()) @map("visited_at")

  session  GameSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  location GameLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([sessionId, locationId])
  @@index([sessionId])
  @@map("location_visits")
}

// ============================================================
// SECTION: Life Tracker Module
// ============================================================

enum TrackerType {
  DESIRE
  EMOTION
  GOAL
  ACHIEVEMENT
}

model TrackerEntry {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  type      TrackerType
  title     String
  content   String?
  score     Int
  tags      String[]
  isPublic  Boolean     @default(false) @map("is_public")
  createdAt DateTime    @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([isPublic, createdAt])
  @@map("tracker_entries")
}
